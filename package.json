{
  "name": "asun-format",
  "version": "0.1.0",
  "description": "Syntax highlighter for ASUN (Array-Schema Unified Notation) — zero deps, browser + Node.js",
  "license": "MIT",
  "type": "module",
  "main": "./dist/asun-format.cjs",
  "module": "./dist/asun-format.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/asun-format.js",
      "require": "./dist/asun-format.cjs"
    },
    "./css": "./dist/asun-format.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly --outDir dist && node build.mjs",
    "dev": "node build.mjs && echo 'open examples/demo.html in a browser'",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asunLab/js-format.git",
    "directory": "js-format"
  },
  "homepage": "https://github.com/asunLab/js-format#readme",
  "bugs": {
    "url": "https://github.com/asunLab/js-format/issues"
  },
  "keywords": [
    "asun",
    "syntax-highlight",
    "formatter",
    "code-highlight"
  ],
  "sideEffects": [
    "./dist/asun-format.css"
  ]
}