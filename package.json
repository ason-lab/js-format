{
  "name": "ason-format",
  "version": "0.1.0",
  "description": "Syntax highlighter for ASON (Array-Schema Object Notation) — zero deps, browser + Node.js",
  "license": "MIT",
  "type": "module",
  "main": "./dist/ason-format.cjs",
  "module": "./dist/ason-format.js",
  "types": "./dist/ason-format.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/ason-format.d.ts",
      "import":  "./dist/ason-format.js",
      "require": "./dist/ason-format.cjs"
    },
    "./css": "./dist/ason-format.css"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly --outDir dist && node build.mjs",
    "dev":   "node build.mjs && echo 'open examples/demo.html in a browser'",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ason-lab/js-format.git",
    "directory": "js-format"
  },
  "homepage": "https://github.com/ason-lab/js-format#readme",
  "bugs": {
    "url": "https://github.com/ason-lab/js-format/issues"
  },
  "keywords": ["ason", "syntax-highlight", "formatter", "code-highlight"],
  "sideEffects": [
    "./dist/ason-format.css"
  ]
}
